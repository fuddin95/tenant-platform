# Database — Postgres (ca-central-1 for PIPEDA compliance)
# Matches docker-compose postgres service for local dev
DATABASE_URL="postgresql://rentaltrust:rentaltrust@localhost:5432/rentaltrust"

# NextAuth v5 — generate secret with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# AWS S3 — MUST use ca-central-1 (PIPEDA requirement)
# Leave blank until document upload is implemented
AWS_REGION="ca-central-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_KMS_KEY_ID=""

# Backend
PORT=3001

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"
